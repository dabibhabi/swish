      "width": 316.8,
      "height": 192.5,
      "backgroundColor": "transparent",
      "strokeColor": "#74c0fc",
      "roundness": null,
      "text": "init(Window&)  /  cleanup()  /  drawFrame()\nservices() -> RendererServices\nupload_scene_geometry(mesh, draws)\nupload_dynamic_geometry(mesh, draws)\nupdate_dynamic_draw_calls(draws)   <- per frame\nrebuild_material_descriptors()\nset_camera(Camera*)  /  set_scene_lights(lights)\nrecordCommandBuffer(frame, image)\n  recordGBufferPass(cmd, frame, extent)\n  transitionGBufferForLighting(cmd, frame)\n  recordLightingPass(cmd, frame, extent)\n  recordBloomExtract / recordBloomBlur(h|v)\n  recordCompositePass(cmd, frame, image, extent)\nrecreateSwapchain()",
      "originalText": "init(Window&)  /  cleanup()  /  drawFrame()\nservices() -> RendererServices\nupload_scene_geometry(mesh, draws)\nupload_dynamic_geometry(mesh, draws)\nupdate_dynamic_draw_calls(draws)   <- per frame\nrebuild_material_descriptors()\nset_camera(Camera*)  /  set_scene_lights(lights)\nrecordCommandBuffer(frame, image)\n  recordGBufferPass(cmd, frame, extent)\n  transitionGBufferForLighting(cmd, frame)\n  recordLightingPass(cmd, frame, extent)\n  recordBloomExtract / recordBloomBlur(h|v)\n  recordCompositePass(cmd, frame, image, extent)\nrecreateSwapchain()",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "lineHeight": 1.25,
      "containerId": null,
      "autoResize": true
